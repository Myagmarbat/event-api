# Local development (no SSL)
DATABASE_URL=postgresql://user:password@localhost:5432/events

# For DigitalOcean Managed PostgreSQL (SSL required):
# DATABASE_URL=postgresql://user:password@host:port/dbname?sslmode=require
# 1. Download the CA cert from DO dashboard -> Databases -> your cluster -> Connection details
# 2. Save it to certs/do-ca-cert.crt (certs/ is gitignored)
# 3. Set DB_SSL_CA to the path below
DB_SSL_CA=certs/do-ca-cert.crt