# -----------------------------------------------
# Local integration tests (no SSL)
# -----------------------------------------------
DATABASE_URL=postgresql://postgres:password@localhost:5432/integration_db

# -----------------------------------------------
# DigitalOcean Managed PostgreSQL (SSL required)
# -----------------------------------------------
# For CI: set DATABASE_URL secret in GitHub → points to integration_db
# For prod: set DATABASE_URL secret in GitHub → points to production_db
#
# DATABASE_URL=postgresql://user:password@do-host:25060/integration_db?sslmode=require
# DB_SSL_CA=certs/do-ca-cert.crt
DB_SSL_CA=