# -----------------------------------------------
# Local integration tests (no SSL)
# -----------------------------------------------
DATABASE_URL=postgresql://postgres:password@localhost:5432/defaultdb

# -----------------------------------------------
# DigitalOcean Managed PostgreSQL (SSL required)
# -----------------------------------------------
# For CI: set DATABASE_URL secret in GitHub → points to defaultdb
# For prod: set DATABASE_URL secret in GitHub → points to production_db
#
# DATABASE_URL=postgresql://user:password@do-host:25060/defaultdb?sslmode=require
# DB_SSL_CA=certs/do-ca-cert.crt
# IMAGE=registry.digitalocean.com/your-registry/event-api:latest
DB_SSL_CA=
